    const endIndex = startIndex + limit;

    return {
      page,
      limit,
      total: MOCK_FOLLOWERS.length, 
      followers: MOCK_FOLLOWERS.slice(startIndex, endIndex), 
    };
  }

  const res = await api.get(`/social/${userId}/followers`, {
    params: { page, limit },
  });
  return res.data;
};

