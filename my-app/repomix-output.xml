  }) => (
    <div data-testid="timestamped-comments">
      <button onClick={() => onSeek?.(0.5)}>Seek waveform</button>
    </div>
  ),
}));

describe("HistoryTrackRow", () => {
  const track = {
    trackId: "trk_1",
    title: "Layali",
    artist: "Ahmed Hassan",
    artistId: "usr_1",
    artistHandle: "ahmed",
    artistAvatarUrl: null,
    coverArtUrl: "/cover.jpg",
    liked: false,
    likesCount: 10,
    reposted: false,
    repostsCount: 3,
    playedAt: "2026-04-12T10:00:00Z",
    positionSeconds: 30,
    durationSeconds: 180,
    isCompleted: false,
  };

  beforeEach(() => {
    jest.clearAllMocks();

    mockUsePlayerStore.mockReturnValue({
      currentTrack: null,
      isPlaying: false,
      toggle: mockToggle,
