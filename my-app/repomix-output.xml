import api from "./api";
import { TrackData, UserInteractionResponse } from "../types/interactions";

export interface RepostResponse {
  message: string;
  trackId: string;
  repostsCount: number;
  reposted: boolean;
}

export const repostTrack = async (trackId: string): Promise<RepostResponse> => {
