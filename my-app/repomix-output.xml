  it("renders formatted current time and duration", () => {
    render(<ProgressBar />);
    expect(screen.getByText("0:30")).toBeInTheDocument();
    expect(screen.getByText("2:00")).toBeInTheDocument();
  });

  it("calls seekTo with clicked position", () => {
