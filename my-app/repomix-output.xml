    const root = screen.getByTestId("waveform-display").parentElement as HTMLDivElement;
    fireEvent.mouseEnter(root);

    await waitFor(() => {
      expect(mockGetTrackComments).toHaveBeenCalledWith("trk_1", 1, 100);
    });
