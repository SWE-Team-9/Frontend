        {/* ── SUCCESS TOAST ── */}
        {showSuccessToast && (
          <div className="fixed top-20 right-10 z-100 animate-in slide-in-from-right duration-300">
            <div className="bg-[#333] border border-zinc-700 p-4 flex items-center gap-4 shadow-2xl rounded-sm min-w-75">
