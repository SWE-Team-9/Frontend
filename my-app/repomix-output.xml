                    : "border-yellow-500 text-yellow-400"
              }`}
            >
              {track.status}
            </span>
            <span
              className={`text-xs font-semibold px-3 py-1 rounded-full border ${
                track.visibility === "PUBLIC"
                  ? "border-blue-400 text-blue-400"
                  : "border-gray-500 text-gray-400"
