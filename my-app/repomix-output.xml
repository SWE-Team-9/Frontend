        isPlayingAd: mockStoreState.isPlayingAd,
        currentAd: mockStoreState.currentAd,
        adElapsedSeconds: mockStoreState.adElapsedSeconds,
        hydratedFromSession: true,
      };

      return typeof selector === "function" ? selector(state) : state;
