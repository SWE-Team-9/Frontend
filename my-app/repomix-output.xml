"use client";
import React from "react";
import { AvatarUpload } from "@/src/components/profile/AvatarUpload";
import { CoverPhoto } from "@/src/components/profile/CoverPhoto";

interface ProfileHeaderProps {
  displayName: string;
  location: string;
