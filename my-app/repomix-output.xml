            ? "bg-zinc-800 text-zinc-400 border border-zinc-700 hover:text-white"
            : "bg-white text-black hover:bg-zinc-200"
        }`}
      >
        {loading ? "..." : following ? "Following" : "Follow"}
      </button>
      {error && <p className="text-[10px] text-red-400">{error}</p>}
    </div>
  );
}
